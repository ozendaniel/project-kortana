# Database
DATABASE_URL=postgresql://kortana:kortana@localhost:5432/kortana

# Platform credentials (Phase 1: personal use)
DOORDASH_EMAIL=your@email.com
SEAMLESS_EMAIL=your@email.com
SEAMLESS_PASSWORD=your_password

# Google Maps (for geocoding + address autocomplete)
GOOGLE_MAPS_API_KEY=

# Server
PORT=3001
NODE_ENV=development

# Chrome path override (auto-detected if empty)
CHROME_PATH=

# Profile storage directory (default: ~/.kortana/)
# On Railway: mount a persistent volume and set to /data/.kortana/
PROFILE_STORAGE_DIR=

# WebSocket auth secret (optional — skip for personal/localhost use)
WS_AUTH_SECRET=
